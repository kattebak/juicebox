{
  "name": "as-me",
  "description": "Scoped GitHub App wrapper for gh and git — manifest-bounded permissions instead of full OAuth.",
  "url": "https://github.com/kattebak/as-me",
  "public": false,
  "request_oauth_on_install": true,
  "redirect_url": "http://127.0.0.1:8765/manifest-callback",
  "callback_urls": ["http://127.0.0.1:8765/callback"],
  "default_events": [],
  "default_permissions": {
    "contents": "write",
    "pull_requests": "write",
    "issues": "write",
    "metadata": "read",
    "statuses": "write"
  }
}
